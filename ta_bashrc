# SANE DEFAULTS

# save multi-line commands as one command
shopt -s cmdhist

# Лічильник промптів для періодичного показу таймеру
_ta_prompt_counter=0

function prompt_command() {
    history -a
    $TA_BIN $CHALLENGE_FILE

    # Отримуємо ліміт часу поточного рівня
    local TIME_LIMIT=$($TA_BIN --get-level-timelimit $CHALLENGE_FILE 2>/dev/null)

    # Перевіряємо чи час вичерпано
    if [ -n "$TIME_LIMIT" ] && [ "$TIME_LIMIT" != "0" ] && [ "$TIME_LIMIT" != "-1" ]; then
        if $TA_BIN --check-level-time $CHALLENGE_FILE 2>/dev/null; then
            echo ""
            echo "⏰ Час на цей рівень вичерпано!"
            echo ""
            # Можна додати авто-перехід або вихід — залежно від бажання
            # exit 0  # розкоментувати для авто-виходу
        fi

        # Отримуємо залишок часу
        local REMAINING=$($TA_BIN --print-level-timer $CHALLENGE_FILE 2>/dev/null)
        if [ -n "$REMAINING" ] && [ "$REMAINING" != "-1" ] && [ "$REMAINING" -gt 0 ] 2>/dev/null; then
            local mins=$((REMAINING / 60))
            local secs=$((REMAINING % 60))
            local TIME_STR=$(printf "%dm %02ds" $mins $secs)
        else
            local TIME_STR="0m 00s"
        fi
        export PS1="\\t [$TIME_STR] $($TA_BIN --print-identifier $CHALLENGE_FILE)[\u@\H:\w]\$ "
    else
        export PS1='\t $($TA_BIN --print-identifier $CHALLENGE_FILE)[\u@\H:\w]$ '
    fi
}
export PROMPT_COMMAND=prompt_command
export PS1="\t [\u@\H:\w]$ "
force_color_prompt=yes

# history
export HISTFILESIZE=500
export HISTSIZE=500
export HISTFILE=$HOME/.tahistory
export HISTCONTROL=ignoredups

# aliases
alias ls='ls -C --color=auto'
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'
alias l.='ls -d .* --color=auto'

alias grep='grep --color=auto'
